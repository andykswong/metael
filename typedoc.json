    "packages/lang/src/index.ts",
    "packages/runtime/src/index.ts",
    "packages/vdom/src/index.ts",
    "packages/vdom/src/lang/index.ts",
    "packages/gpu/src/index.ts",
    "packages/gpu/src/lang/index.ts",
    "packages/gpu/src/builder/index.ts",
    "packages/math/src/core/index.ts",
    "packages/math/src/lang/index.ts",
    "packages/std/src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "apps/site/public/api",
