{
  "name": "metael",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:packages": "npm run build --ws --if-present",
    "clean": "npm run clean --ws --if-present && rimraf dist *.tsbuildinfo",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && npm run typecheck --ws --if-present",
    "test": "vitest run --passWithNoTests",
    "test:node": "vitest run --project node --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0",
    "@types/node": "^26.0",
    "eslint": "^10.0",
    "globals": "^17.0",
    "rimraf": "^6.0",
    "typescript": "^6.0",
    "typescript-eslint": "^8.50",
    "vite": "^8.1",
    "vite-plugin-dts": "^5.0",
    "vitest": "^4.1"
  },
  "workspaces": ["./packages/lang"]
}
