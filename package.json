{
  "name": "metael",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepublishOnly": "npm run clean && npm run build:packages && npm test && npm run docs:api",
    "build:packages": "npm run build --ws --if-present",
    "clean": "npm run clean --ws --if-present && rimraf dist *.tsbuildinfo",
    "lint": "eslint",
    "docs:api": "typedoc",
    "typecheck": "tsc --noEmit && npm run typecheck --ws --if-present",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser"
  },
  "devDependencies": {
    "@eslint/js": "^10.0",
    "@types/node": "^26.0",
    "@vitest/browser-playwright": "^4.1",
    "eslint": "^10.0",
    "globals": "^17.0",
    "playwright": "^1.61",
    "rimraf": "^6.0",
    "typedoc": "^0.28",
    "typescript": "^6.0",
    "typescript-eslint": "^8.50",
    "vite": "^8.1",
    "vite-plugin-dts": "^5.0",
    "vitest": "^4.1"
  },
  "workspaces": [
    "./packages/lang",
    "./packages/runtime",
    "./packages/vdom",
    "./apps/site"
  ]
}
