{
  "name": "@metael/math",
  "version": "0.1.0",
  "description": "metael math — a zero-dependency numeric library of vector, matrix, and quaternion operations.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": { "types": "./dist/core/index.d.ts", "import": "./dist/core/index.js" },
    "./lang": { "types": "./dist/lang/index.d.ts", "import": "./dist/lang/index.js" }
  },
  "files": ["/dist"],
  "engines": { "node": ">=24.0" },
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "prebuild": "npm run lint",
    "build": "vite build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/math"
  },
  "repository": { "type": "git", "url": "git+https://github.com/andykswong/metael.git", "directory": "packages/math" },
  "keywords": ["metael", "math", "vector", "matrix", "quaternion", "typescript"],
  "author": "Andy K.S. Wong <andykswong@outlook.com>",
  "license": "MIT",
  "bugs": { "url": "https://github.com/andykswong/metael/issues" },
  "homepage": "https://github.com/andykswong/metael#readme",
  "publishConfig": { "access": "public", "provenance": true },
  "dependencies": { "@metael/lang": "^0.1.0" }
}
